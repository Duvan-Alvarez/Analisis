GOOGLE_API_KEY=your-google-api-key-here
SECRET_KEY=your-secret-key-change-in-production-12345
GEMINI_MODEL=gemini-flash-latest

# Optional deployment/storage settings
# DATA_DIR=/data
# UPLOAD_DIR=/data/uploads
# DATABASE_URL=sqlite:////data/cv_analysis_history.db

# Optional MySQL/MariaDB database for vacancies managed with phpMyAdmin
# VACANTES_DATABASE_URL=mysql+pymysql://user:password@host:3306/database?charset=utf8mb4
# VACANTES_QUERY=SELECT id, titulo, area, contrato, fecha, descripcion FROM vacantes ORDER BY fecha DESC LIMIT 50

# Get your free API key at: https://aistudio.google.com/app/apikey
# Then copy it here and rename this file to .env (do NOT commit .env to git)

# For production:
# - Change SECRET_KEY to a strong random string
# - Use Railway variables instead of committing .env

